<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:BBCD3_Desktop"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit" 
    x:Class="BBCD3_Desktop.MainWindow"
    mc:Ignorable="d"
    Style="{DynamicResource CustomWindowStyle}"
    Title="BBCD3" 
    Height="509" 
    Width="887"
    Background="#212121">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
            <Image Width="45" Height="45" Source="bbcd_logo-white.png" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock Text="BBCD3" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       VerticalAlignment="Center" 
                       Margin="15,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,30,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <DockPanel Margin="0,0,0,5">
                        <Button x:Name="BackButton" 
                    Content="← Back" 
                    Click="BackButton_Click" 
                    Visibility="Collapsed" 
                    Background="Transparent" 
                    Foreground="#007ACC" 
                    FontWeight="Bold"
                    BorderThickness="0" 
                    Padding="0" 
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    VerticalAlignment="Center"/>
                        <TextBlock x:Name="CategoryHeader" Text="Pick a channel category" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ListBox x:Name="ChannelsGridList"
                 Height="150" Margin="0,0,0,20" Background="#1A1A1A"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="ChannelsGridList_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" Margin="4"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="85" Height="70" Margin="4">
                                    <Border x:Name="BgBorder" Background="#282828" CornerRadius="4" BorderThickness="1" BorderBrush="#383838"/>
                                    <Grid Margin="4">
                                        <TextBlock Text="{Binding DisplayName}" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       TextAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center" 
                                       TextWrapping="Wrap"/>
                                    </Grid>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BgBorder" Property="Background" Value="#333333"/>
                                        <Setter TargetName="BgBorder" Property="BorderBrush" Value="#444444"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="BgBorder" Property="Background" Value="#007ACC"/>
                                        <Setter TargetName="BgBorder" Property="BorderBrush" Value="#0096FF"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Schedule (Date &amp; Start Time)" Foreground="#AAAAAA" Margin="0,0,0,5" FontSize="12"/>
                    <UniformGrid Columns="2" Margin="0,0,0,20">
                        <DatePicker x:Name="DatePicker" 
                        FirstDayOfWeek="Monday" 
                        VerticalAlignment="Center" 
                        Margin="0,0,10,0"/>
                        <xctk:TimePicker x:Name="StartTimePicker" 
                             Height="28"
                             Background="#242424" 
                             Foreground="White" 
                             BorderBrush="#333333" 
                             VerticalAlignment="Center"/>
                    </UniformGrid>
                    <TextBlock Text="Duration (Hours / Minutes / Seconds)" Foreground="#AAAAAA" Margin="0,0,0,5" FontSize="12"/>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,15,0">
                            <xctk:IntegerUpDown x:Name="DurationHours" Value="0" Minimum="0" Maximum="12" Width="60" Height="28" Background="#242424" Foreground="White" BorderBrush="#333333"/>
                            <TextBlock Text="HH" Foreground="#666666" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <xctk:IntegerUpDown x:Name="DurationMinutes" Value="0" Minimum="0" Maximum="59" Width="60" Height="28" Background="#242424" Foreground="White" BorderBrush="#333333"/>
                            <TextBlock Text="MM" Foreground="#666666" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel>
                            <xctk:IntegerUpDown x:Name="DurationSeconds" Value="0" Minimum="0" Maximum="59" Width="60" Height="28" Background="#242424" Foreground="White" BorderBrush="#333333"/>
                            <TextBlock Text="SS" Foreground="#666666" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>



            </Grid>

        <StackPanel Grid.Column="1" VerticalAlignment="Top">
            <TextBlock Text="Settings" Foreground="#AAAAAA" Margin="0,0,0,10" FontSize="12"/>

                <CheckBox x:Name="EncodeCheckbox" 
                          Content="Enable Encoding (iOS Support)" 
                          ToolTip="Takes longer but allows iOS devices to view recordings" 
                          Foreground="White" 
                          IsChecked="False"
                          Margin="0,0,0,10"/>

                <CheckBox x:Name="FastModeCheckbox" 
                          Content="Use Fast Mode" 
                          IsChecked="True"
                          ToolTip="Disable this if you have issues with downloads failing. Downloads segments sequentially." 
                          Foreground="White" 
                          Margin="0,0,0,20"/>

                <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,0,0,20"/>

                <Button x:Name="DownloadButton" 
                        Content="START DOWNLOAD" 
                        Height="45" 
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#007ACC" 
                        Foreground="White"
                        Click="DownloadButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="DownloadPath" 
                        Content="Change Download Folder" 
                        Margin="0,12,0,0" 
                        Height="30"
                        Background="Transparent"
                        Foreground="#AAAAAA"
                        BorderBrush="#444444"
                        Click="ChangePathBtn_Click"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <DockPanel LastChildFill="True" Margin="0,0,0,5">
                <TextBlock x:Name="StatusText" 
                           Text="Status: Ready" 
                           FontSize="14" 
                           Foreground="White" 
                           VerticalAlignment="Bottom"/>
                <TextBlock x:Name="SavePathText" 
                           Text="Saving to: Downloads" 
                           FontSize="11" 
                           Foreground="#666666" 
                           TextAlignment="Right" 
                           VerticalAlignment="Bottom"/>
            </DockPanel>

            <ProgressBar x:Name="StatusProgress" 
                         Height="12" 
                         Background="#333333" 
                         BorderThickness="0">
                <ProgressBar.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </ProgressBar.Resources>
            </ProgressBar>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="BBCD3_Desktop.PrettyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BBCD3_Desktop"
        mc:Ignorable="d"
        Style="{DynamicResource CustomWindowStyle}"
        Title="Update Available" Height="300" Width="620" WindowStyle="ToolWindow">

    <Grid Background="#212121">

        <Border BorderBrush="{x:Null}" Margin="17,10,17,0" VerticalAlignment="Top" Height="22">
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" Foreground="White" FontSize="14" 
                       HorizontalAlignment="Center" VerticalAlignment="Top" 
                       Text="A new version is available."/>
        </Border>
        <TextBox x:Name="ChangelogBox" Margin="28,37,28,62" 
             Background="#333" Foreground="White" BorderThickness="0"
             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" 
             Padding="5"/>


        <Button x:Name="BtnDownload" Content="Download" Click="BtnDownload_Click" Margin="0,0,290,21" VerticalAlignment="Bottom" Height="36" FontWeight="Bold" HorizontalAlignment="Right" Width="100"/>

        <Button x:Name="BtnLater" Content="Remind Me Later" Click="BtnLater_Click" Margin="0,0,163,21" VerticalAlignment="Bottom" Height="36" HorizontalAlignment="Right" Width="100"/>

        <Button x:Name="BtnSkip" Content="Skip this version" Click="BtnSkip_Click" Margin="0,0,38,21" Background="#333" Foreground="#AAA" Height="36" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="100"/>

    </Grid>
</Window>